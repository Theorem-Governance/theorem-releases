{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theorem-governance.github.io/release-manifest.schema.json",
  "title": "Theorem Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "version",
    "release_date",
    "compatibility_classification",
    "release_lifecycle",
    "release_channel",
    "support_tiers",
    "security_release_policy",
    "release_notes",
    "metadata_authentication",
    "upgrade_contract",
    "summary",
    "capabilities",
    "capability_negotiation",
    "principal_contract",
    "stable_error_taxonomy",
    "act_contract",
    "schema_changes",
    "api_changes",
    "required_operator_actions",
    "bootstrap_specification",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "product": { "type": "string" },
    "version": { "type": "string" },
    "release_date": { "type": "string", "format": "date-time" },
    "compatibility_classification": {
      "type": "string",
      "enum": [
        "compatible-additive",
        "compatible-behavior-tightening",
        "breaking-major"
      ]
    },
    "release_lifecycle": { "$ref": "#/$defs/releaseLifecycle" },
    "release_channel": { "$ref": "#/$defs/releaseChannel" },
    "support_tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/supportTier" }
    },
    "security_release_policy": { "$ref": "#/$defs/securityReleasePolicy" },
    "release_notes": { "$ref": "#/$defs/releaseNotes" },
    "metadata_authentication": { "$ref": "#/$defs/metadataAuthentication" },
    "upgrade_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line",
        "major_version_boundary_rule",
        "deprecation_window_policy",
        "behavior_change_policy"
      ],
      "properties": {
        "line": { "type": "string" },
        "major_version_boundary_rule": { "type": "string" },
        "deprecation_window_policy": { "type": "string" },
        "behavior_change_policy": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/upgradePath" }
        }
      }
    },
    "summary": { "type": "string" },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["new", "changed", "deprecated", "removed"],
      "properties": {
        "new": { "$ref": "#/$defs/changeArray" },
        "changed": { "$ref": "#/$defs/changeArray" },
        "deprecated": { "$ref": "#/$defs/changeArray" },
        "removed": { "$ref": "#/$defs/changeArray" }
      }
    },
    "capability_negotiation": { "$ref": "#/$defs/capabilityNegotiation" },
    "principal_contract": { "$ref": "#/$defs/principalContract" },
    "stable_error_taxonomy": { "$ref": "#/$defs/stableErrorTaxonomy" },
    "act_contract": { "$ref": "#/$defs/actContract" },
    "schema_changes": {
      "type": "array",
      "items": { "$ref": "#/$defs/changeRecord" }
    },
    "api_changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "removed"],
      "properties": {
        "added": {
          "type": "array",
          "items": { "$ref": "#/$defs/apiChange" }
        },
        "removed": {
          "type": "array",
          "items": { "$ref": "#/$defs/apiChange" }
        }
      }
    },
    "required_operator_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bootstrap_specification": { "$ref": "#/$defs/bootstrapSpecification" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "release_integrity": { "$ref": "#/$defs/releaseIntegrity" },
    "human_release_notes_url": { "type": "string" },
    "release_url": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^v4\\."
          }
        },
        "required": ["version"]
      },
      "then": {
        "required": ["release_integrity"]
      }
    },
    {
      "if": {
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^v0\\.(?:[6-9]|[1-9][0-9]+)\\."
          }
        },
        "required": ["version"]
      },
      "then": {
        "properties": {
          "upgrade_contract": {
            "required": ["paths"]
          }
        }
      }
    }
  ],
  "$defs": {
    "changeArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/changeRecord" }
    },
    "changeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "contract_surface": { "type": "string" }
      }
    },
    "capabilityNegotiation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "contract_line",
        "stability_rule",
        "consumer_rules",
        "capabilities"
      ],
      "properties": {
        "surface": { "type": "string" },
        "contract_line": { "type": "string" },
        "stability_rule": { "type": "string" },
        "consumer_rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/negotiatedCapability" }
        }
      }
    },
    "negotiatedCapability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "availability", "stability"],
      "properties": {
        "id": { "type": "string" },
        "availability": { "type": "string" },
        "stability": { "type": "string" }
      }
    },
    "principalContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id_field",
        "principal_id_field",
        "grantor_id_field",
        "authorization_route",
        "semantics"
      ],
      "properties": {
        "entity_id_field": { "type": "string" },
        "principal_id_field": { "type": "string" },
        "grantor_id_field": { "type": "string" },
        "authorization_route": { "type": "string" },
        "semantics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "stableErrorTaxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "legacy_behavior", "taxonomy"],
      "properties": {
        "scope": { "type": "string" },
        "legacy_behavior": { "type": "string" },
        "taxonomy": {
          "type": "array",
          "items": { "$ref": "#/$defs/errorTaxonomyEntry" }
        }
      }
    },
    "errorTaxonomyEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "http_status",
        "content_type",
        "body_fields",
        "error_codes"
      ],
      "properties": {
        "surface": { "type": "string" },
        "http_status": { "type": "integer" },
        "content_type": { "type": "string" },
        "body_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "error_codes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "actContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declare_intent", "submit_act"],
      "properties": {
        "declare_intent": { "$ref": "#/$defs/declareIntentContract" },
        "submit_act": { "$ref": "#/$defs/submitActContract" }
      }
    },
    "releaseLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "support_statement",
        "security_support",
        "eol_action"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["preview", "active", "security-only", "eol"]
        },
        "support_statement": { "type": "string" },
        "security_support": { "type": "string" },
        "eol_action": { "type": "string" },
        "supported_until": { "type": "string", "format": "date-time" },
        "superseded_by": { "type": "string" }
      }
    },
    "releaseChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "promotion_policy",
        "freeze_policy",
        "servicing_mode",
        "published_branch"
      ],
      "properties": {
        "name": { "type": "string" },
        "promotion_policy": { "type": "string" },
        "freeze_policy": { "type": "string" },
        "servicing_mode": { "type": "string" },
        "published_branch": { "type": "string" }
      }
    },
    "supportTier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "tier",
        "release_blocking",
        "test_depth",
        "security_servicing",
        "deprecation_policy"
      ],
      "properties": {
        "target": { "type": "string" },
        "tier": {
          "type": "string",
          "enum": ["Primary", "Legacy", "Planned"]
        },
        "release_blocking": { "type": "boolean" },
        "test_depth": { "type": "string" },
        "security_servicing": { "type": "string" },
        "deprecation_policy": { "type": "string" }
      }
    },
    "securityReleasePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_channel",
        "severity_classes",
        "release_cadence",
        "emergency_release_rule",
        "metadata_key_rotation"
      ],
      "properties": {
        "advisory_channel": { "type": "string" },
        "severity_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "release_cadence": { "type": "string" },
        "emergency_release_rule": { "type": "string" },
        "metadata_key_rotation": { "type": "string" }
      }
    },
    "releaseNotes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_name", "public_path", "format", "summary"],
      "properties": {
        "asset_name": { "type": "string" },
        "public_path": { "type": "string" },
        "format": {
          "type": "string",
          "enum": ["markdown"]
        },
        "summary": { "type": "string" },
        "operator_highlights": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metadataAuthentication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_root_path",
        "verification_rule",
        "required_roles"
      ],
      "properties": {
        "trust_root_path": { "type": "string" },
        "verification_rule": { "type": "string" },
        "required_roles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "declareIntentContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "principal_field", "timing_fields", "enforcement_rule"],
      "properties": {
        "route": { "type": "string" },
        "principal_field": { "type": "string" },
        "timing_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enforcement_rule": { "type": "string" }
      }
    },
    "submitActContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "principal_field",
        "authorization_field",
        "resource_consumption_field",
        "resource_consumption_entry_fields",
        "elapsed_time_surfaces"
      ],
      "properties": {
        "route": { "type": "string" },
        "principal_field": { "type": "string" },
        "authorization_field": { "type": "string" },
        "resource_consumption_field": { "type": "string" },
        "resource_consumption_entry_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "elapsed_time_surfaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "apiChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path", "summary"],
      "properties": {
        "method": { "type": "string" },
        "path": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "upgradePath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_version",
        "to_version",
        "mode",
        "artifact_kind",
        "machine_executable",
        "state_strategy",
        "rollback_strategy",
        "operator_guide"
      ],
      "properties": {
        "from_version": { "type": "string" },
        "to_version": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": [
            "reimage-and-restore",
            "in-place-boot-environment-upgrade",
            "uefi-esp-upgrade"
          ]
        },
        "artifact_kind": {
          "type": "string",
          "enum": [
            "direct-write-disk-image",
            "installer-rootfs",
            "upgrade-bundle",
            "uefi-esp-image"
          ]
        },
        "machine_executable": { "type": "boolean" },
        "requires_reboot": { "type": "boolean" },
        "state_strategy": { "type": "string" },
        "rollback_strategy": { "type": "string" },
        "operator_guide": { "type": "string" },
        "target_boot_environment": { "type": "string" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "size_bytes"],
      "properties": {
        "name": { "type": "string" },
        "sha256": { "type": "string" },
        "size_bytes": { "type": "integer" },
        "artifact_kind": {
          "type": "string",
          "enum": [
            "single-binary",
            "installer-rootfs",
            "upgrade-bundle",
            "install-media",
            "direct-write-disk-image",
            "uefi-esp-image",
            "uefi-kernel",
            "uefi-loader",
            "boot-contract",
            "specification-document",
            "specification-hash",
            "checksum",
            "sbom",
            "provenance",
            "evidence",
            "other"
          ]
        },
        "target": { "type": "string" },
        "format": { "type": "string" },
        "automation_strategy": { "type": "string" },
        "self_contained_bootstrap": { "type": "boolean" },
        "bootstrap_strategy": { "type": "string" },
        "direct_disk_write": {
          "type": "string",
          "enum": ["allowed", "forbidden", "not-applicable"]
        },
        "archive_root": { "type": "string" },
        "installer_entrypoint": { "type": "string" },
        "upgrade_entrypoint": { "type": "string" },
        "first_boot_config_path": { "type": "string" },
        "first_boot_config_template": { "type": "string" },
        "first_boot_config_policy": { "type": "string" },
        "supported_upgrade_from": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_boot_environment": { "type": "string" },
        "state_preservation": { "type": "string" },
        "seed_partition_label": { "type": "string" },
        "seed_filesystem": { "type": "string" },
        "bootable": { "type": "boolean" }
      }
    },
    "bootstrapSpecification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_algorithm",
        "spec_hash",
        "document_asset_name",
        "document_public_path",
        "document_sha256",
        "hash_asset_name",
        "hash_public_path"
      ],
      "properties": {
        "hash_algorithm": {
          "type": "string",
          "enum": ["sha256"]
        },
        "spec_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "document_asset_name": { "type": "string" },
        "document_public_path": { "type": "string" },
        "document_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "hash_asset_name": { "type": "string" },
        "hash_public_path": { "type": "string" }
      }
    },
    "releaseIntegrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_ring",
        "evidence_asset_path",
        "sbom_assets",
        "provenance_assets",
        "minimum_version",
        "downgrade_prevention_rule",
        "rollback_authorization",
        "revocation",
        "mirror_policy"
      ],
      "properties": {
        "release_ring": { "type": "string" },
        "evidence_asset_path": { "type": "string" },
        "sbom_assets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "provenance_assets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "minimum_version": { "type": "string" },
        "downgrade_prevention_rule": { "type": "string" },
        "rollback_authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rule", "required_approval_count", "authorized_roles"],
          "properties": {
            "rule": { "type": "string" },
            "required_approval_count": { "type": "integer", "minimum": 1 },
            "authorized_roles": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "revocation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ledger_path", "record_path"],
          "properties": {
            "ledger_path": { "type": "string" },
            "record_path": { "type": "string" }
          }
        },
        "mirror_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "feed_path",
            "mirror_generated_at",
            "mirror_expires_at",
            "mirror_ttl_hours",
            "stale_behavior"
          ],
          "properties": {
            "feed_path": { "type": "string" },
            "mirror_generated_at": { "type": "string", "format": "date-time" },
            "mirror_expires_at": { "type": "string", "format": "date-time" },
            "mirror_ttl_hours": { "type": "integer", "minimum": 1 },
            "stale_behavior": {
              "type": "string",
              "enum": ["fail_closed"]
            }
          }
        }
      }
    }
  }
}
