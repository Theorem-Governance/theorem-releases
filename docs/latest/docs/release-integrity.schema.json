{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theorem-governance.github.io/release-integrity.schema.json",
  "title": "Theorem Release Integrity Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product",
    "version",
    "release_date",
    "generated_at",
    "manifest",
    "bootstrap_specification",
    "release_ring",
    "minimum_version",
    "downgrade_prevention_rule",
    "rollback_authorization",
    "binary_assets",
    "sbom_assets",
    "provenance_assets",
    "revocation",
    "mirror_policy"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "product": { "type": "string" },
    "version": { "type": "string" },
    "release_date": { "type": "string", "format": "date-time" },
    "generated_at": { "type": "string", "format": "date-time" },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "asset_name", "sha256"],
      "properties": {
        "path": { "type": "string" },
        "asset_name": { "type": "string" },
        "sha256": { "type": "string" }
      }
    },
    "bootstrap_specification": { "$ref": "#/$defs/bootstrapSpecification" },
    "release_ring": { "type": "string" },
    "minimum_version": { "type": "string" },
    "downgrade_prevention_rule": { "type": "string" },
    "rollback_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "required_approval_count", "authorized_roles"],
      "properties": {
        "rule": { "type": "string" },
        "required_approval_count": { "type": "integer", "minimum": 1 },
        "authorized_roles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "binary_assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "uefi_assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "sbom_assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "provenance_assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_path", "record_path"],
      "properties": {
        "ledger_path": { "type": "string" },
        "record_path": { "type": "string" }
      }
    },
    "mirror_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feed_path",
        "mirror_generated_at",
        "mirror_expires_at",
        "mirror_ttl_hours",
        "stale_behavior"
      ],
      "properties": {
        "feed_path": { "type": "string" },
        "mirror_generated_at": { "type": "string", "format": "date-time" },
        "mirror_expires_at": { "type": "string", "format": "date-time" },
        "mirror_ttl_hours": { "type": "integer", "minimum": 1 },
        "stale_behavior": {
          "type": "string",
          "enum": ["fail_closed"]
        }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "size_bytes"],
      "properties": {
        "name": { "type": "string" },
        "sha256": { "type": "string" },
        "size_bytes": { "type": "integer" },
        "artifact_kind": {
          "type": "string",
          "enum": [
            "single-binary",
            "installer-rootfs",
            "upgrade-bundle",
            "install-media",
            "direct-write-disk-image",
            "uefi-esp-image",
            "uefi-kernel",
            "uefi-loader",
            "boot-contract",
            "specification-document",
            "specification-hash",
            "checksum",
            "sbom",
            "provenance",
            "evidence",
            "other"
          ]
        },
        "target": { "type": "string" },
        "format": { "type": "string" },
        "automation_strategy": { "type": "string" },
        "self_contained_bootstrap": { "type": "boolean" },
        "bootstrap_strategy": { "type": "string" },
        "direct_disk_write": {
          "type": "string",
          "enum": ["allowed", "forbidden", "not-applicable"]
        },
        "archive_root": { "type": "string" },
        "installer_entrypoint": { "type": "string" },
        "upgrade_entrypoint": { "type": "string" },
        "first_boot_config_path": { "type": "string" },
        "first_boot_config_template": { "type": "string" },
        "first_boot_config_policy": { "type": "string" },
        "supported_upgrade_from": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_boot_environment": { "type": "string" },
        "state_preservation": { "type": "string" },
        "seed_partition_label": { "type": "string" },
        "seed_filesystem": { "type": "string" },
        "bootable": { "type": "boolean" }
      }
    },
    "bootstrapSpecification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_algorithm",
        "spec_hash",
        "document_asset_name",
        "document_public_path",
        "document_sha256",
        "hash_asset_name",
        "hash_public_path"
      ],
      "properties": {
        "hash_algorithm": {
          "type": "string",
          "enum": ["sha256"]
        },
        "spec_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "document_asset_name": { "type": "string" },
        "document_public_path": { "type": "string" },
        "document_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "hash_asset_name": { "type": "string" },
        "hash_public_path": { "type": "string" }
      }
    }
  }
}
