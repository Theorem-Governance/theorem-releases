  "principal_contract": {
    "entity_id_field": "entity_id",
    "principal_id_field": "principal_id",
    "grantor_id_field": "granted_by_id",
    "authorization_route": "GET /authorizations?entity_id={entity_id}",
    "semantics": [
      "entity_id names the acting or queried entity on public request surfaces.",
      "principal_id names the entity holding authority on authorization surfaces.",
      "granted_by_id names the grantor and must not be interpreted as the principal.",
      "GET /authorizations returns authorizations held by the queried principal entity, not authorizations granted by it."
    ]
  },
  "stable_error_taxonomy": {
    "scope": "Stable for the published 5.0 discovery, organization, lifecycle, release-verification, and governed-release routes in openapi.yaml.",
    "legacy_behavior": "Legacy pre-4.0 routes may still return text/plain bodies and are outside this stable taxonomy.",
    "taxonomy": [
      {
        "surface": "5.0 public routes",
        "http_status": 400,
        "content_type": "application/json",
        "body_fields": [
          "error_code",
          "message"
        ],
        "error_codes": [
          "not_bootstrapped",
          "entity_not_found",
          "scope_not_found",
          "request_hash_failed",
          "serialization_failed"
        ]
      },
      {
        "surface": "5.0 public routes",
        "http_status": 409,
        "content_type": "application/json",
        "body_fields": [
          "error_code",
          "message"
        ],
        "error_codes": [
          "idempotency_conflict"
        ]
      },
      {
        "surface": "5.0 public routes",
        "http_status": 422,
        "content_type": "application/json",
        "body_fields": [
          "error_code",
          "message"
        ],
        "error_codes": [
          "action_admission_inactive",
          "action_admission_not_found",
          "execution_capability_binding_mismatch",
          "execution_capability_expired",
          "execution_capability_not_found",
          "execution_capability_secret_mismatch",
          "governance_authority_required",
          "intervention_path_authority_required",
          "principal_not_trusted"
        ]
      }
    ]
  },
  "act_contract": {
    "declare_intent": {
      "route": "POST /declare-intent",
      "principal_field": "entity_id",
      "timing_fields": [
        "declared_at",
        "minimum_wait_ms",
        "earliest_execution_at"
      ],
      "enforcement_rule": "Acts must satisfy E4: declared_at plus minimum_intent_execution_interval_ms must be less than or equal to initiated_at."
    },
    "submit_act": {
      "route": "POST /submit-act",
      "principal_field": "executing_entity_id",
      "authorization_field": "authorization_id",
      "resource_consumption_field": "resource_consumption_entries",
      "resource_consumption_entry_fields": [
        "resource_type",
        "quantity",
        "unit",
        "measurement_method_id",
        "measured_at",
        "within_limits",
        "escalation_signal_id"
      ],
      "elapsed_time_surfaces": [
        "declare-intent response declared_at",
        "declare-intent response minimum_wait_ms",
        "declare-intent response earliest_execution_at",
        "submit-act response initiated_at",
        "submit-act response intent_declared_at",
        "submit-act response elapsed_ms_since_declared"
      ]
    }
  },
  "schema_changes": [],
  "api_changes": {
    "added": [],
