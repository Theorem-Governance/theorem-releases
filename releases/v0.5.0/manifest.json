  "required_operator_actions": [
    "Consume releases/feed.json, releases/v0.5.0/manifest.json, and releases/v0.5.0/integrity.json before mirroring or admitting a 5.x release.",
    "Deploy on FreeBSD 14.4-RELEASE or later with ZFS root pool named 'theorem'.",
    "Use theoremos-v0.5.0-amd64-direct-write.img.xz for unattended bare-metal direct disk writes; use theoremos-v0.5.0-x86_64-unknown-freebsd.tar.gz only for installer-driven bare-metal flows; treat ISO and memstick assets as install media only.",
    "Install theorem-init to /sbin/theorem-init and remaining binaries to /usr/local/bin/.",
    "Load PF kernel module and configure /etc/pf.conf with theorem anchor.",
    "Review /etc/veriexec.d/theorem.manifest and optionally load mac_veriexec for verified execution."
  ],
