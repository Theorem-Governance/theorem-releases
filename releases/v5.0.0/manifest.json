  "principal_contract": {
    "entity_id_field": "entity_id",
    "principal_id_field": "principal_id",
    "grantor_id_field": "granted_by_id",
    "authorization_route": "GET /authorizations?entity_id={entity_id}",
    "semantics": [
      "entity_id names the acting or queried entity on public request surfaces.",
      "principal_id names the entity holding authority on authorization surfaces.",
      "granted_by_id names the grantor and must not be interpreted as the principal.",
      "GET /authorizations returns authorizations held by the queried principal entity, not authorizations granted by it."
    ]
  },
  "stable_error_taxonomy": {
    "scope": "Stable for the published 5.0 discovery, organization, lifecycle, release-verification, and governed-release routes in openapi.yaml.",
    "legacy_behavior": "Legacy pre-4.0 routes may still return text/plain bodies and are outside this stable taxonomy.",
    "taxonomy": [
      {
        "surface": "5.0 public routes",
        "http_status": 400,
        "content_type": "application/json",
