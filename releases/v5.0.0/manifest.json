{
  "schema_version": "1.2.0",
  "product": "theorem-node",
  "version": "v5.0.0",
  "release_date": "2026-03-24T22:27:13Z",
  "compatibility_classification": "breaking-major",
  "upgrade_contract": {
    "line": "5.x",
    "major_version_boundary_rule": "Breaking removals and incompatible semantic changes require a major version boundary.",
    "deprecation_window_policy": "Machine-consumable surfaces remain available for at least one full minor release after deprecation is published in a manifest.",
    "behavior_change_policy": "Behavior changes that tighten validation or deny previously accepted input must be classified in the manifest."
  },
  "summary": "Theorem 5.0 is the release where Theorem becomes a complete FreeBSD-native OS from PID 1 to organizational authority. It extends the 4.0 governed platform contract with a full substrate layer: ZFS-backed storage, jail-based compute, PF networking, hardware device governance, encrypted secret management, governed image pipelines, distributed fabric, economic settlement, branch reality, and autonomous governance runtime. Built natively on FreeBSD 14.4-RELEASE with all cfg(target_os = freebsd) gates active.",
  "capabilities": {
    "new": [
      {
        "id": "substrate.zfs-storage",
        "summary": "ZFS dataset lifecycle, content-addressed artifact store, boot environments, snapshot management, and pool governance via theorem-zfs.",
        "contract_surface": "theorem-init store, theorem-zfs"
      },
      {
        "id": "substrate.jail-compute",
        "summary": "FreeBSD jail-based workload isolation with governance admission, RCTL resource limits, and lifecycle management via theorem-compute.",
        "contract_surface": "theorem-init workload, theorem-compute"
      },
      {
        "id": "substrate.pf-networking",
        "summary": "PF firewall rule governance via pf anchors, crossing policy enforcement, and network isolation via theorem-net.",
        "contract_surface": "theorem-net"
      },
      {
        "id": "substrate.encrypted-secrets",
        "summary": "Argon2id+AES-256-GCM secret sealing with Capsicum capability restriction for admin operations via theorem-secrets and theorem-crypto.",
        "contract_surface": "theorem-secrets, theorem-crypto"
      },
      {
        "id": "substrate.veriexec-integrity",
        "summary": "MAC veriexec verified execution manifest for all theorem binaries with SHA-256 hashes.",
        "contract_surface": "theorem-init, /etc/theorem/veriexec.manifest"
      },
      {
        "id": "substrate.pid1-supervisor",
        "summary": "theorem-init PID 1 supervisor with governance runtime, quarantine escalation, service graph, alert dispatch, and boot attestation.",
        "contract_surface": "theorem-init run"
      },
      {
        "id": "substrate.branch-reality",
        "summary": "ZFS-backed counterfactual governance lanes with branch engine, timeline graph, merge strategy, and fork ledger via theorem-branch.",
        "contract_surface": "theorem-branch"
      },
      {
        "id": "substrate.autonomous-governance",
        "summary": "Intent compiler, self-challenger, drift detector, circuit breaker, and path-not-taken recording via theorem-auto.",
        "contract_surface": "theorem-auto"
      },
      {
        "id": "substrate.economic-settlement",
        "summary": "Crossing settlement, privacy budgets, escrow ledger, and data retention via theorem-econ and theorem-settle.",
        "contract_surface": "theorem-econ, theorem-settle"
      },
      {
        "id": "substrate.distributed-fabric",
        "summary": "Fleet mesh and distributed compute fabric via theorem-fabric.",
        "contract_surface": "theorem-fabric"
      },
      {
        "id": "substrate.governed-images",
        "summary": "Staged rollout image pipeline with governance controls via theorem-image.",
        "contract_surface": "theorem-image"
      },
      {
        "id": "substrate.device-governance",
        "summary": "Hardware device governance with devfs ruleset management via theorem-devices.",
        "contract_surface": "theorem-devices"
      }
    ],
    "changed": [
      {
        "id": "release.governed-publication",
        "summary": "Release publication now targets FreeBSD x86_64 as the primary platform. Linux artifacts are no longer the authoritative production target.",
        "contract_surface": "public release contract"
      }
    ],
    "deprecated": [],
    "removed": []
  },
